.container { min-height: 100vh; background: #f5f6fa; padding-bottom: 120rpx; }
.header { display: flex; align-items: center; justify-content: space-between; padding: 32rpx 32rpx 16rpx; }
.header-title { font-size: 32rpx; font-weight: 700; color: #333; }
.btn-clear { font-size: 26rpx; color: #e74c3c; padding: 8rpx 16rpx; }
.loading-wrap { display: flex; justify-content: center; padding: 80rpx; }
.loading-text { font-size: 26rpx; color: #999; }
.empty { display: flex; flex-direction: column; align-items: center; padding: 120rpx 32rpx; }
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 32rpx; color: #555; margin-bottom: 12rpx; }
.empty-sub { font-size: 26rpx; color: #aaa; }
.list { padding: 0 24rpx; display: flex; flex-direction: column; gap: 16rpx; }
.item { padding: 20rpx 24rpx; }
.item-top { display: flex; gap: 16rpx; align-items: flex-start; margin-bottom: 16rpx; }
.item-cover { width: 120rpx; height: 90rpx; border-radius: 10rpx; flex-shrink: 0; background: #f0f0f0; }
.item-cover-ph { width: 120rpx; height: 90rpx; border-radius: 10rpx; background: #f0f0ff; display: flex; align-items: center; justify-content: center; font-size: 40rpx; flex-shrink: 0; }
.item-info { flex: 1; overflow: hidden; }
.item-title { display: block; font-size: 26rpx; color: #222; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 8rpx; }
.item-meta { display: flex; gap: 8rpx; align-items: center; margin-bottom: 6rpx; }
.tag-platform { font-size: 20rpx; color: #667eea; background: #f0f0ff; padding: 2rpx 12rpx; border-radius: 20rpx; }
.item-author { font-size: 20rpx; color: #888; }
.item-time { font-size: 20rpx; color: #bbb; }
.btn-del { font-size: 22rpx; color: #d03050; background: #fff0f0; padding: 8rpx 16rpx; border-radius: 20rpx; flex-shrink: 0; }
.download-area { border-top: 1rpx solid #f0f0f0; padding-top: 14rpx; display: flex; flex-direction: column; gap: 10rpx; }
.dl-row { display: flex; align-items: center; justify-content: space-between; padding: 10rpx 16rpx; background: #f8f9ff; border-radius: 10rpx; }
.quality-tag { font-size: 24rpx; font-weight: 600; color: #333; }
.dl-btns { display: flex; gap: 10rpx; }
.btn-download { background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; padding: 12rpx 28rpx; border-radius: 30rpx; font-size: 24rpx; text-align: center; min-width: 100rpx; }
.btn-downloading { background: linear-gradient(135deg, #999, #bbb) !important; }
.btn-copy { background: #f0f0ff; color: #667eea; padding: 12rpx 24rpx; border-radius: 30rpx; font-size: 24rpx; }
.float-progress { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 20rpx 32rpx; box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.1); z-index: 100; }
.float-label { display: block; font-size: 26rpx; color: #667eea; font-weight: 500; margin-bottom: 12rpx; }
.progress-bar-bg { height: 12rpx; background: #e8eaff; border-radius: 6rpx; overflow: hidden; }
.progress-bar-fill { height: 100%; background: linear-gradient(90deg, #667eea, #764ba2); border-radius: 6rpx; transition: width 0.2s ease; }
