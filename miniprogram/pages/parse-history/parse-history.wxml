<view class="container">
  <view class="header">
    <text class="header-title">🔍 解析历史</text>
    <view class="btn-clear" bindtap="clearAll" wx:if="{{list.length > 0}}">清空</view>
  </view>

  <view class="loading-wrap" wx:if="{{pageLoading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <view class="empty" wx:elif="{{list.length === 0}}">
    <text class="empty-icon">🔍</text>
    <text class="empty-text">暂无解析记录</text>
    <text class="empty-sub">去解析一个视频吧～</text>
  </view>

  <view class="list" wx:else>
    <view class="item card" wx:for="{{list}}" wx:key="id">
      <!-- 视频信息 -->
      <view class="item-top">
        <image class="item-cover" src="{{item.cover}}" mode="aspectFill" wx:if="{{item.cover}}" />
        <view class="item-cover-ph" wx:else><text>🎬</text></view>
        <view class="item-info">
          <text class="item-title">{{item.title || '无标题'}}</text>
          <view class="item-meta">
            <text class="tag-platform">{{platformMap[item.platform] || item.platform}}</text>
            <text class="item-author" wx:if="{{item.author}}">👤 {{item.author}}</text>
          </view>
          <text class="item-time">{{item.timeStr}}</text>
        </view>
        <view class="btn-del" bindtap="deleteItem" data-id="{{item.id}}">删除</view>
      </view>

      <!-- 下载按钮区 -->
      <view class="download-area" wx:if="{{item.videoUrls && item.videoUrls.length > 0}}">
        <view class="dl-row" wx:for="{{item.videoUrls}}" wx:for-item="v" wx:for-index="vi" wx:key="vi">
          <text class="quality-tag">{{v.quality}}</text>
          <view class="dl-btns">
            <view
              class="btn-download {{downloadingKey === item.id + '-' + vi ? 'btn-downloading' : ''}}"
              bindtap="downloadVideo"
              data-item="{{item}}"
              data-url="{{v.url}}"
              data-quality="{{v.quality}}"
              data-vi="{{vi}}"
            >
              <text wx:if="{{downloadingKey === item.id + '-' + vi}}">{{downloadProgress}}%</text>
              <text wx:else>⬇️ 下载</text>
            </view>
            <view class="btn-copy" bindtap="copyUrl" data-url="{{v.url}}">复制</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 悬浮进度条 -->
  <view class="float-progress" wx:if="{{downloadStatus}}">
    <text class="float-label">{{downloadStatus === 'saving' ? '⏳ 保存中...' : '⬇️ 下载中 ' + downloadProgress + '%'}}</text>
    <view class="progress-bar-bg">
      <view class="progress-bar-fill" style="width: {{downloadStatus === 'saving' ? 100 : downloadProgress}}%"></view>
    </view>
  </view>
</view>
