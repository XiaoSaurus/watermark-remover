.login-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx;
}

.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 80rpx;
}

.logo {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.login-types {
  display: flex;
  justify-content: center;
  margin-bottom: 60rpx;
}

.type-item {
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  padding: 30rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 180rpx;
  transition: all 0.3s;
  border: 2rpx solid transparent;
  margin-left: 10rpx;
  margin-right: 10rpx;
}

.type-item:first-child {
  margin-left: 0;
}

.type-item:last-child {
  margin-right: 0;
}

.type-item.active {
  background: rgba(255,255,255,0.95);
  border-color: #fff;
}

.type-item .icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.type-item .label {
  font-size: 24rpx;
  color: #fff;
}

.type-item.active .label {
  color: #6c63ff;
}

.form {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.input-group {
  background: #f8f9ff;
  border: 2rpx solid #e8eaf6;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.input {
  font-size: 28rpx;
  width: 100%;
}

.sms-row {
  display: flex;
  align-items: center;
}

.sms-btn {
  background: #6c63ff;
  color: #fff;
  font-size: 24rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  white-space: nowrap;
  min-width: 160rpx;
  margin-left: 20rpx;
}

.sms-btn[disabled] {
  background: #ccc;
}

.btn-primary {
  background: linear-gradient(135deg, #6c63ff, #764ba2);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-top: 20rpx;
  border: none;
}

.wechat-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.link {
  color: #6c63ff;
  margin-left: 8rpx;
}

.btn-wechat {
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  border: none;
}

.btn-wechat-code {
  background: #f0f0f0;
  color: #666;
  font-size: 26rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  border: none;
}

.tourist-tip {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  margin-bottom: 30rpx;
}

.tourist-tip text {
  display: block;
  margin-bottom: 10rpx;
}

.bottom-links {
  display: flex;
  justify-content: center;
  margin-top: 40rpx;
  color: #fff;
  font-size: 26rpx;
}

.bottom-links text {
  margin-left: 10rpx;
  margin-right: 10rpx;
}

.divider {
  opacity: 0.5;
}
