.login-page {
  min-height: 100vh;
  background: #f7f8fa;
  display: flex;
  flex-direction: column;
}

/* 顶部返回 */
.top-bar {
  padding: 20rpx 30rpx;
  padding-top: var(--status-bar-height, 50rpx);
}

.back-btn {
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 50%;
  border: 1rpx solid #e5e7eb;
}

.back-icon {
  font-size: 40rpx;
  color: #374151;
  font-weight: bold;
  line-height: 1;
}

/* 品牌区域 */
.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 60rpx;
}

.logo-wrap {
  width: 160rpx;
  height: 160rpx;
  background: #6c63ff;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(108, 99, 255, 0.22);
}

.logo {
  font-size: 56rpx;
  font-weight: 800;
  color: #fff;
}

.brand-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #111827;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.brand-sub {
  font-size: 26rpx;
  color: #6b7280;
}

/* 登录卡片 */
.login-card {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  flex: 1;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.1);
}

/* Tab 切换 */
.tab-bar {
  display: flex;
  background: #f5f5f9;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 40rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #999;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: #fff;
  color: #6c63ff;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(108, 99, 255, 0.2);
}

/* 输入区域 */
.input-wrap {
  margin-bottom: 30rpx;
}

.input-item {
  display: flex;
  align-items: center;
  background: #f8f9ff;
  border: 2rpx solid #e8eaf6;
  border-radius: 16rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  transition: all 0.3s ease;
}

.input-item.focus {
  border-color: #6c63ff;
  box-shadow: 0 4rpx 20rpx rgba(108, 99, 255, 0.15);
  background: #fff;
}

.input-left {
  display: flex;
  align-items: center;
  padding-right: 16rpx;
  margin-right: 16rpx;
  border-right: 1rpx solid #eee;
  position: relative;
}

.input-key {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #6c63ff;
  background: #eef2ff;
  border-radius: 10rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.input-prefix {
  font-size: 26rpx;
  color: #333;
  margin-left: 8rpx;
  font-weight: 500;
}

.input-line {
  width: 1rpx;
  height: 32rpx;
  background: #ddd;
  margin-left: 16rpx;
}

.input-field {
  flex: 1;
  height: 96rpx;
  font-size: 28rpx;
  color: #333;
}

.code-btn {
  background: #6c63ff;
  color: #fff;
  font-size: 24rpx;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  border: none;
  white-space: nowrap;
  min-width: 160rpx;
}

.code-btn.cooldown {
  background: #ccc;
}

/* 登录按钮 */
.btn-login {
  background: #6c63ff;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 28rpx;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(108, 99, 255, 0.22);
  transition: all 0.3s ease;
}

.btn-login:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(108, 99, 255, 0.2);
}

/* 卡片底部 */
.card-bottom {
  display: flex;
  justify-content: center;
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.link-text {
  font-size: 24rpx;
  color: #999;
}

.link-divider {
  margin: 0 20rpx;
  color: #ddd;
}

.link-primary {
  color: #6c63ff;
}

/* 微信授权 */
.wechat-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.wechat-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  background: #07c160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.wechat-icon {
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
}

.wechat-tip-main {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.wechat-tip-sub {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.agreement-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  margin-top: 20rpx;
  margin-bottom: 30rpx;
}

.agreement-text {
  font-size: 22rpx;
  color: #999;
}

.agreement-link {
  font-size: 22rpx;
  color: #6c63ff;
}

.btn-wechat {
  width: 100%;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 28rpx;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.4);
  transition: all 0.3s ease;
}

.btn-wechat:active {
  transform: scale(0.98);
}

.btn-wechat-text {
  letter-spacing: 4rpx;
}

/* 游客模式 */
.tourist-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.tourist-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  background: #eef2ff;
  border: 1rpx solid #e5e7eb;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.tourist-icon {
  font-size: 52rpx;
  font-weight: 800;
  color: #6c63ff;
}

.tourist-tip-main {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.tourist-tip-sub {
  font-size: 26rpx;
  color: #999;
}

.mt10 {
  margin-top: 10rpx;
}

.btn-tourist {
  width: 100%;
  background: #6c63ff;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 28rpx;
  border-radius: 16rpx;
  border: none;
  margin-top: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(108, 99, 255, 0.22);
  transition: all 0.3s ease;
}

.btn-tourist:active {
  transform: scale(0.98);
}

.tourist-notice {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 20rpx;
  text-align: center;
}