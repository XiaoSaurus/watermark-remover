<view class="login-page">
  <!-- 顶部返回 -->
  <view class="top-bar">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
  </view>

  <!-- 品牌区域 -->
  <view class="brand">
    <view class="logo-wrap">
      <text class="logo">✂️</text>
    </view>
    <text class="brand-title">去水印工具</text>
    <text class="brand-sub">专业视频图片去水印</text>
  </view>

  <!-- 登录卡片 -->
  <view class="login-card">
    <!-- Tab 切换 -->
    <view class="tab-bar">
      <view class="tab-item {{tabIndex === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">
        <text>手机号登录</text>
      </view>
      <view class="tab-item {{tabIndex === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">
        <text>微信授权</text>
      </view>
      <view class="tab-item {{tabIndex === 2 ? 'active' : ''}}" bindtap="switchTab" data-index="2">
        <text>游客试用</text>
      </view>
    </view>

    <!-- 手机号登录 -->
    <view class="tab-content" wx:if="{{tabIndex === 0}}">
      <view class="input-wrap">
        <view class="input-item {{focusField === 'phone' ? 'focus' : ''}}">
          <view class="input-left">
            <text class="input-icon">📱</text>
            <text class="input-prefix">+86</text>
            <view class="input-line"></view>
          </view>
          <input class="input-field" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" bindfocus="onFieldFocus" bindblur="onFieldBlur" data-field="phone" />
        </view>
        <view class="input-item {{focusField === 'code' ? 'focus' : ''}}">
          <view class="input-left">
            <text class="input-icon">🔐</text>
          </view>
          <input class="input-field" type="number" maxlength="6" placeholder="请输入验证码" value="{{code}}" bindinput="onCodeInput" bindfocus="onFieldFocus" bindblur="onFieldBlur" data-field="code" />
          <button class="code-btn {{smsCooldown > 0 ? 'cooldown' : ''}}" bindtap="sendSms" disabled="{{smsLoading || smsCooldown > 0}}">
            {{smsCooldown > 0 ? smsCooldown + 's' : (smsLoading ? '发送中' : '获取验证码')}}
          </button>
        </view>
      </view>
      <button class="btn-login" bindtap="handleLogin" loading="{{loading}}">
        <text>登 录</text>
      </button>
      <view class="card-bottom">
        <text class="link-text" bindtap="goReset">忘记密码？</text>
        <text class="link-divider">|</text>
        <text class="link-text link-primary" bindtap="goRegister">注册账号</text>
      </view>
    </view>

    <!-- 微信授权 -->
    <view class="tab-content" wx:if="{{tabIndex === 1}}">
      <view class="wechat-wrap">
        <view class="wechat-icon-wrap">
          <text class="wechat-icon">💬</text>
        </view>
        <text class="wechat-tip-main">微信一键登录</text>
        <text class="wechat-tip-sub">便捷安全，无需记住密码</text>
        <view class="agreement-row">
          <text class="agreement-text">登录即表示同意</text>
          <text class="agreement-link">《用户服务协议》</text>
          <text class="agreement-text">和</text>
          <text class="agreement-link">《隐私政策》</text>
        </view>
        <button class="btn-wechat" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
          <text class="btn-wechat-text">微信授权登录</text>
        </button>
      </view>
    </view>

    <!-- 游客试用 -->
    <view class="tab-content" wx:if="{{tabIndex === 2}}">
      <view class="tourist-wrap">
        <view class="tourist-icon-wrap">
          <text class="tourist-icon">👤</text>
        </view>
        <text class="tourist-tip-main">游客模式</text>
        <text class="tourist-tip-sub">无需注册，直接体验全部功能</text>
        <text class="tourist-tip-sub mt10">数据本地保存，登录后可同步</text>
        <button class="btn-tourist" bindtap="handleTouristLogin" loading="{{loading}}">
          <text>进入游客模式</text>
        </button>
        <text class="tourist-notice">登录后仍可升级为正式账号，数据不丢失</text>
      </view>
    </view>
  </view>
</view>
