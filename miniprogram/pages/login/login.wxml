<view class="login-page">
  <!-- 顶部品牌 -->
  <view class="brand">
    <text class="logo">✂️</text>
    <text class="title">去水印工具</text>
  </view>

  <!-- 登录方式选择 -->
  <view class="login-types">
    <view class="type-item {{loginType=='phone'?'active':''}}" bindtap="selectType" data-type="phone">
      <text class="icon">📱</text>
      <text class="label">手机号登录</text>
    </view>
    <view class="type-item {{loginType=='wechat'?'active':''}}" bindtap="selectType" data-type="wechat">
      <text class="icon">💬</text>
      <text class="label">微信授权登录</text>
    </view>
    <view class="type-item {{loginType=='tourist'?'active':''}}" bindtap="selectType" data-type="tourist">
      <text class="icon">👤</text>
      <text class="label">游客登录</text>
    </view>
  </view>

  <!-- 手机号表单 -->
  <view class="form" wx:if="{{loginType=='phone'}}">
    <view class="form-title">手机号登录</view>
    <view class="input-group">
      <input class="input" placeholder="请输入手机号" type="number" maxlength="11" bindinput="onPhoneInput" value="{{phone}}" />
    </view>
    <view class="input-group sms-row">
      <input class="input" placeholder="请输入6位验证码" type="number" maxlength="6" bindinput="onCodeInput" value="{{code}}" />
      <button class="sms-btn {{smsLoading || smsCooldown>0 ? 'disabled' : ''}}" bindtap="sendSms" disabled="{{smsLoading || smsCooldown>0}}">
        {{smsCooldown > 0 ? smsCooldown + 's' : '获取验证码'}}
      </button>
    </view>
    <button class="btn-primary" bindtap="handleLogin" loading="{{loading}}">登录</button>
  </view>

  <!-- 微信授权 -->
  <view class="form" wx:if="{{loginType=='wechat'}}">
    <view class="form-title">微信授权登录</view>
    <view class="wechat-tip">
      <text>点击下方按钮，即表示同意</text>
      <text class="link">《用户服务协议》</text>
    </view>
    <button class="btn-wechat" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
      <text>微信授权登录</text>
    </button>
    <button class="btn-wechat-code" bindtap="handleWechatLogin">
      <text>使用微信码登录（备用）</text>
    </button>
  </view>

  <!-- 游客登录 -->
  <view class="form" wx:if="{{loginType=='tourist'}}">
    <view class="form-title">游客登录</view>
    <view class="tourist-tip">
      <text>游客账号默认密码为 123456</text>
      <text>登录后可升级为正式账号</text>
    </view>
    <button class="btn-primary" bindtap="handleTouristLogin">游客登录</button>
  </view>

  <!-- 底部链接 -->
  <view class="bottom-links">
    <text bindtap="goRegister">注册账号</text>
    <text class="divider">|</text>
    <text bindtap="goReset">忘记密码</text>
  </view>
</view>
