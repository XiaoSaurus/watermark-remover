.user-page {
  min-height: 100vh;
  background: #f5f5f8;
}

/* 用户头部 */
.user-header {
  position: relative;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 120rpx 40rpx 60rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  z-index: 0;
}

.user-info-wrapper {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.avatar-wrapper {
  position: relative;
  width: 140rpx;
  height: 140rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.edit-icon {
  font-size: 24rpx;
}

.user-text-info {
  flex: 1;
  margin-left: 30rpx;
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.login-type-badge {
  width: 100%;
  margin-top: 20rpx;
  padding-left: 170rpx;
}

.login-type-text {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 30rpx;
  font-size: 22rpx;
  color: #fff;
}

/* 会员卡片 */
.vip-card {
  margin: -30rpx 30rpx 30rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #ffd700, #ffb347);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(255, 179, 71, 0.4);
}

.vip-left {
  display: flex;
  align-items: center;
}

.vip-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.vip-icon {
  font-size: 40rpx;
}

.vip-info {
  display: flex;
  flex-direction: column;
}

.vip-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.vip-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 6rpx;
}

.vip-btn {
  padding: 12rpx 30rpx;
  background: #fff;
  color: #ff9800;
  font-size: 24rpx;
  font-weight: bold;
  border-radius: 30rpx;
  border: none;
}

.vip-active-tag {
  padding: 12rpx 30rpx;
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
  font-size: 24rpx;
  border-radius: 30rpx;
}

/* 数据统计 */
.stats-card {
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.stat-value.points {
  color: #ff6b6b;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
}

/* 信息区域 */
.info-section {
  margin: 0 30rpx 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.info-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-left {
  display: flex;
  align-items: center;
}

.info-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.info-label {
  font-size: 28rpx;
  color: #333;
}

.info-right {
  display: flex;
  align-items: center;
  max-width: 60%;
}

.info-value {
  font-size: 26rpx;
  color: #999;
  text-align: right;
}

.info-value.bio-text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 10rpx;
}

/* 操作按钮 */
.action-section {
  padding: 20rpx 30rpx 40rpx;
  display: flex;
  flex-direction: column;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.action-btn.primary .btn-icon,
.action-btn.primary .btn-text {
  color: #fff;
}

.action-btn.danger {
  background: #fff;
}

.action-btn.danger .btn-icon,
.action-btn.danger .btn-text {
  color: #ff6b6b;
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.btn-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 未登录状态 */
.not-login {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.not-login-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.not-login-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: -200rpx;
}

.logo-wrapper {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.logo {
  font-size: 80rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 60rpx;
}

.btn-login {
  padding: 24rpx 80rpx;
  background: #fff;
  color: #667eea;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.guest-tip {
  margin-top: 30rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 模态框 */
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #999;
}

.modal-content {
  padding: 30rpx;
  max-height: 50vh;
}

.avatar-upload {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.avatar-upload-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #eee;
  margin-bottom: 16rpx;
}

.avatar-tip {
  font-size: 22rpx;
  color: #999;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #fafafa;
}

.form-input:focus {
  border-color: #667eea;
  background: #fff;
}

.form-textarea {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #fafafa;
  min-height: 150rpx;
}

.form-textarea:focus {
  border-color: #667eea;
  background: #fff;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.gender-select {
  display: flex;
  gap: 20rpx;
}

.gender-item {
  flex: 1;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
}

.gender-item.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

.picker-value {
  padding: 24rpx;
  background: #fafafa;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.picker-value.placeholder {
  color: #999;
}

.code-input-group {
  display: flex;
  gap: 16rpx;
}

.code-input-group .form-input {
  flex: 1;
}

.btn-code {
  padding: 0 24rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 26rpx;
  border-radius: 12rpx;
  border: none;
  white-space: nowrap;
}

.btn-code[disabled] {
  background: #ccc;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #eee;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-confirm {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}
