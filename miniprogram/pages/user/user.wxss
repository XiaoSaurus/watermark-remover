.user-page {
  min-height: 100vh;
  background: #f0f2f8;
  padding: 0;
}

.user-header {
  background: linear-gradient(135deg, #6c63ff, #764ba2);
  padding: 50rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
  flex-shrink: 0;
}

.user-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.username {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.login-type {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  background: rgba(255,255,255,0.2);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
  width: fit-content;
  margin-bottom: 6rpx;
}

.user-id {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
}

/* 等级和积分卡片 */
.level-card {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 20rpx 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.level-item, .points-item, .vip-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.level-icon, .vip-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.level-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.level-name {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

.points-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.points-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

.vip-text {
  font-size: 24rpx;
  color: #ff9800;
  font-weight: 600;
}

.divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
  margin: 0 20rpx;
}

/* 信息卡片 */
.info-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 20rpx 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 个人简介 */
.bio-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 20rpx 30rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.bio-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
}

.bio-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.btn {
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  color: #fff;
}

.btn-primary {
  background: linear-gradient(135deg, #6c63ff, #764ba2);
}

.btn-secondary {
  background: #f0f0f0;
  color: #333;
}

.btn-danger {
  background: #ff6b6b;
}

/* 未登录状态 */
.not-login {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 150rpx;
}

.logo {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.sub {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 80rpx;
}

.btn-login {
  background: linear-gradient(135deg, #6c63ff, #764ba2);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 24rpx 100rpx;
  border-radius: 50rpx;
  border: none;
}

/* 模态框 */
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  font-size: 32rpx;
  color: #999;
}

.modal-content {
  padding: 30rpx;
  max-height: 400rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 10rpx;
  font-weight: 600;
}

.form-input {
  width: 100%;
  padding: 16rpx 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  padding: 16rpx 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  min-height: 100rpx;
}

.radio-group {
  display: flex;
  gap: 30rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  color: #333;
}

.picker-value {
  padding: 16rpx 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
}

.code-input-group {
  display: flex;
  gap: 10rpx;
}

.code-input-group .form-input {
  flex: 1;
}

.btn-code {
  padding: 16rpx 20rpx;
  background: #6c63ff;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 22rpx;
  white-space: nowrap;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #eee;
}

.btn-cancel {
  flex: 1;
  padding: 20rpx;
  background: #f0f0f0;
  color: #333;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-confirm {
  flex: 1;
  padding: 20rpx;
  background: #6c63ff;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
}
