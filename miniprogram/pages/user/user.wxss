.user-page {
  min-height: 100vh;
  background: #f7f8fa;
}

/* 用户头部 */
.user-header {
  position: relative;
  background: #ffffff;
  border-bottom: 1rpx solid #e5e7eb;
  padding: 120rpx 40rpx 48rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  z-index: 0;
}

.user-info-wrapper {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.avatar-wrapper {
  width: 140rpx;
  height: 140rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 2rpx solid #e5e7eb;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.user-text-info {
  flex: 1;
  margin-left: 30rpx;
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 40rpx;
  font-weight: bold;
  color: #111827;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 22rpx;
  color: #6b7280;
}

.login-type-badge {
  width: 100%;
  margin-top: 20rpx;
  padding-left: 170rpx;
}

.login-type-text {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: #eef2ff;
  border-radius: 30rpx;
  font-size: 22rpx;
  color: #6c63ff;
}

/* 会员卡片 */
.vip-card {
  margin: -30rpx 30rpx 30rpx;
  padding: 30rpx;
  background: #fffbeb;
  border: 1rpx solid #fde68a;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.vip-left {
  display: flex;
  align-items: center;
}

.vip-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  background: #fef3c7;
  border: 1rpx solid #fde68a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.vip-icon {
  font-size: 36rpx;
  font-weight: 800;
  color: #d97706;
}

.vip-info {
  display: flex;
  flex-direction: column;
}

.vip-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #92400e;
}

.vip-desc {
  font-size: 22rpx;
  color: #b45309;
  margin-top: 6rpx;
}

.vip-btn {
  padding: 12rpx 30rpx;
  background: #fff;
  color: #d97706;
  font-size: 24rpx;
  font-weight: bold;
  border-radius: 30rpx;
  border: 1rpx solid #fde68a;
}

.vip-active-tag {
  padding: 12rpx 30rpx;
  background: #fef3c7;
  color: #92400e;
  font-size: 24rpx;
  border-radius: 30rpx;
}

/* 数据统计 */
.stats-card {
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.stat-value.points {
  color: #ff6b6b;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
}

/* 菜单列表 */
.menu-section {
  margin: 0 30rpx 30rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon-letter {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #6c63ff;
  background: #eef2ff;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 退出登录 */
.logout-section {
  padding: 40rpx 30rpx;
}

.logout-btn {
  width: 100%;
  padding: 28rpx;
  background: #fff;
  color: #ff6b6b;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* 未登录状态 */
.not-login {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.not-login-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50vh;
  background: #f7f8fa;
}

.not-login-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: -200rpx;
}

.logo-wrapper {
  width: 160rpx;
  height: 160rpx;
  background: #6c63ff;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(108, 99, 255, 0.22);
}

.logo {
  font-size: 56rpx;
  font-weight: 800;
  color: #fff;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #111827;
  margin-bottom: 16rpx;
}

.sub {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 60rpx;
}

.btn-login {
  padding: 24rpx 80rpx;
  background: #6c63ff;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(108, 99, 255, 0.22);
}

.guest-tip {
  margin-top: 30rpx;
  font-size: 24rpx;
  color: #9ca3af;
}
