<view class="register-page">
  <view class="form">
    <view class="form-title">注册账号</view>
    <view class="input-group">
      <input class="input" placeholder="请输入用户名（可选，留空自动生成）" bindinput="onUsernameInput" value="{{username}}" />
      <view wx:if="{{usernameMessage}}" class="username-status {{usernameStatus}}">
        <text>{{usernameMessage}}</text>
      </view>
    </view>
    <view class="input-group">
      <input class="input" placeholder="请输入手机号" type="number" maxlength="11" bindinput="onPhoneInput" />
    </view>
    <view class="input-group sms-row">
      <input class="input" placeholder="请输入验证码" type="number" maxlength="6" bindinput="onCodeInput" />
      <button class="sms-btn" bindtap="sendSms" disabled="{{smsCooldown>0}}">{{ smsCooldown > 0 ? smsCooldown + 's' : '获取验证码' }}</button>
    </view>
    <view class="input-group">
      <input class="input" placeholder="请输入密码（6位以上）" password bindinput="onPasswordInput" />
    </view>
    <view class="input-group">
      <input class="input" placeholder="请再次输入密码" password bindinput="onConfirmInput" />
    </view>
    <button class="btn-primary" bindtap="handleRegister">注册</button>
    <view class="bottom-links">
      <text bindtap="goLogin">已有账号？去登录</text>
    </view>
  </view>
</view>
