.edit-profile-page {
  min-height: 100vh;
  background: #f5f5f8;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #333;
  font-weight: bold;
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.nav-save {
  width: 120rpx;
  display: flex;
  justify-content: flex-end;
}

.save-btn {
  padding: 12rpx 24rpx;
  background: #6c63ff;
  color: #fff;
  font-size: 26rpx;
  border-radius: 30rpx;
}

/* 头像 */
.avatar-section {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
  background: #fff;
  margin-bottom: 20rpx;
}

.avatar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #eee;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.avatar-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
}

/* 表单 */
.form-section {
  background: #fff;
  padding: 0 30rpx;
}

.form-item {
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.form-input {
  width: 100%;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: #333;
  border: none;
  background: transparent;
}

.form-input::placeholder {
  color: #ccc;
}

/* 性别选择 */
.gender-select {
  display: flex;
  gap: 20rpx;
}

.gender-item {
  flex: 1;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
}

.gender-item.active {
  background: #6c63ff;
  color: #fff;
}

/* 日期选择 */
.picker-value {
  padding: 20rpx 0;
  font-size: 30rpx;
  color: #333;
}

.picker-value.placeholder {
  color: #ccc;
}

/* 文本域 */
.textarea-item {
  padding-bottom: 40rpx;
}

.form-textarea {
  width: 100%;
  min-height: 150rpx;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-textarea::placeholder {
  color: #ccc;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
}
