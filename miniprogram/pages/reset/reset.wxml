<view class="reset-page">
  <!-- 顶部返回 -->
  <view class="top-bar">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="page-title">重置密码</text>
    <view class="placeholder"></view>
  </view>

  <!-- 重置卡片 -->
  <view class="reset-card">
    <view class="form-wrap">
      <!-- 手机号 -->
      <view class="input-group">
        <view class="input-item {{focusField === 'phone' ? 'focus' : ''}}">
          <view class="input-left">
            <text class="input-key">机</text>
            <text class="input-prefix">+86</text>
            <view class="input-line"></view>
          </view>
          <input class="input-field" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" bindfocus="onFieldFocus" bindblur="onFieldBlur" data-field="phone" />
        </view>
      </view>

      <!-- 验证码 -->
      <view class="input-group">
        <view class="input-item {{focusField === 'code' ? 'focus' : ''}}">
          <view class="input-left">
            <text class="input-key">验</text>
          </view>
          <input class="input-field" type="number" maxlength="6" placeholder="请输入验证码" value="{{code}}" bindinput="onCodeInput" bindfocus="onFieldFocus" bindblur="onFieldBlur" data-field="code" />
          <button class="code-btn {{smsCooldown > 0 ? 'cooldown' : ''}}" bindtap="sendSms" disabled="{{smsLoading || smsCooldown > 0}}">
            {{smsCooldown > 0 ? smsCooldown + 's' : (smsLoading ? '发送中' : '获取验证码')}}
          </button>
        </view>
      </view>

      <!-- 新密码 -->
      <view class="input-group">
        <view class="input-item {{focusField === 'password' ? 'focus' : ''}}">
          <view class="input-left">
            <text class="input-key">密</text>
          </view>
          <input class="input-field" password placeholder="请输入新密码（6位以上）" value="{{password}}" bindinput="onPasswordInput" bindfocus="onFieldFocus" bindblur="onFieldBlur" data-field="password" />
        </view>
      </view>

      <!-- 确认密码 -->
      <view class="input-group">
        <view class="input-item {{focusField === 'confirm' ? 'focus' : ''}}">
          <view class="input-left">
            <text class="input-key">密</text>
          </view>
          <input class="input-field" password placeholder="请再次输入新密码" value="{{confirmPassword}}" bindinput="onConfirmInput" bindfocus="onFieldFocus" bindblur="onFieldBlur" data-field="confirm" />
        </view>
      </view>

      <!-- 重置按钮 -->
      <button class="btn-reset" bindtap="handleReset" loading="{{loading}}">
        <text>确认重置</text>
      </button>

      <!-- 底部登录链接 -->
      <view class="bottom-link">
        <text class="link-text">想起密码了？</text>
        <text class="link-text link-primary" bindtap="goLogin">立即登录</text>
      </view>
    </view>
  </view>
</view>