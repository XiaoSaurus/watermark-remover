<view class="reset-page">
  <view class="form">
    <view class="form-title">重置密码</view>
    <view class="input-group">
      <input class="input" placeholder="请输入手机号" type="number" maxlength="11" bindinput="onPhoneInput" />
    </view>
    <view class="input-group sms-row">
      <input class="input" placeholder="请输入验证码" type="number" maxlength="6" bindinput="onCodeInput" />
      <button class="sms-btn" bindtap="sendSms" disabled="{{smsCooldown>0}}">{{ smsCooldown > 0 ? smsCooldown + 's' : '获取验证码' }}</button>
    </view>
    <view class="input-group">
      <input class="input" placeholder="请输入新密码（6位以上）" password bindinput="onPasswordInput" />
    </view>
    <view class="input-group">
      <input class="input" placeholder="请再次输入新密码" password bindinput="onConfirmInput" />
    </view>
    <button class="btn-primary" bindtap="handleReset">确认重置</button>
    <view class="bottom-links">
      <text bindtap="goLogin">想起密码了？去登录</text>
    </view>
  </view>
</view>
