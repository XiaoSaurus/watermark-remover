.reset-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 50%, #8b5cf6 100%);
  display: flex;
  flex-direction: column;
}

/* 顶部返回 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-top: var(--status-bar-height, 50rpx);
}

.back-btn {
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  backdrop-filter: blur(10rpx);
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}

.page-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  flex: 1;
  text-align: center;
}

.placeholder {
  width: 70rpx;
}

/* 重置卡片 */
.reset-card {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  flex: 1;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.1);
  overflow-y: auto;
}

.form-wrap {
  display: flex;
  flex-direction: column;
}

/* 输入组 */
.input-group {
  margin-bottom: 24rpx;
}

.input-item {
  display: flex;
  align-items: center;
  background: #f8f9ff;
  border: 2rpx solid #e8eaf6;
  border-radius: 16rpx;
  padding: 0 24rpx;
  transition: all 0.3s ease;
}

.input-item.focus {
  border-color: #6c63ff;
  box-shadow: 0 4rpx 20rpx rgba(108, 99, 255, 0.15);
  background: #fff;
}

.input-left {
  display: flex;
  align-items: center;
  padding-right: 16rpx;
  margin-right: 16rpx;
  border-right: 1rpx solid #eee;
}

.input-icon {
  font-size: 32rpx;
}

.input-prefix {
  font-size: 26rpx;
  color: #333;
  margin-left: 8rpx;
  font-weight: 500;
}

.input-line {
  width: 1rpx;
  height: 32rpx;
  background: #ddd;
  margin-left: 16rpx;
}

.input-field {
  flex: 1;
  height: 96rpx;
  font-size: 28rpx;
  color: #333;
}

.code-btn {
  background: linear-gradient(135deg, #6c63ff, #764ba2);
  color: #fff;
  font-size: 24rpx;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  border: none;
  white-space: nowrap;
  min-width: 160rpx;
}

.code-btn.cooldown {
  background: #ccc;
}

/* 重置按钮 */
.btn-reset {
  background: linear-gradient(135deg, #6c63ff, #764ba2);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 28rpx;
  border-radius: 16rpx;
  border: none;
  margin-top: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(108, 99, 255, 0.4);
  transition: all 0.3s ease;
}

.btn-reset:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(108, 99, 255, 0.3);
}

/* 底部登录链接 */
.bottom-link {
  display: flex;
  justify-content: center;
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.link-text {
  font-size: 26rpx;
  color: #999;
}

.link-primary {
  color: #6c63ff;
  margin-left: 8rpx;
}