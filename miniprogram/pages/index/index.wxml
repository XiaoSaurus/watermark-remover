<view class="page">
  <!-- Hero Banner -->
  <view class="hero">
    <view class="hero-badge">✨ 免费 · 无广告 · 无水印</view>
    <text class="hero-title">短视频去水印</text>
    <text class="hero-sub">抖音 · 快手 · B站 · 微博 · 小红书</text>
    <view class="platform-chips">
      <view class="chip" wx:for="{{platforms}}" wx:key="name">{{item.icon}} {{item.name}}</view>
    </view>
  </view>

  <!-- 输入卡片 -->
  <view class="card input-card">
    <view class="input-label">🔗 粘贴分享链接</view>
    <textarea
      class="url-input"
      value="{{inputUrl}}"
      bindinput="onInput"
      placeholder="粘贴视频分享链接或分享文案&#10;例如：https://v.douyin.com/xxxxx/"
      maxlength="-1"
      auto-height
    />
    <view class="btn-row">
      <view class="btn-clear-sm" bindtap="clearInput" wx:if="{{inputUrl}}">
        🗑 清空
      </view>
      <button class="btn-primary btn-parse"
        bindtap="handleParse"
        disabled="{{!inputUrl || loading}}"
        loading="{{loading}}">
        {{loading ? '解析中...' : '🚀 立即解析'}}
      </button>
    </view>
  </view>

  <!-- 解析结果 -->
  <view class="card result-card" wx:if="{{result}}">
    <!-- 视频信息 -->
    <view class="result-header">
      <view class="cover-wrap">
        <image class="cover-img" src="{{result.cover}}" mode="aspectFill" wx:if="{{result.cover}}" />
        <view class="cover-placeholder" wx:else><text>🎬</text></view>
        <view class="cover-platform-badge">{{platformLabel}}</view>
      </view>
      <view class="result-meta">
        <text class="result-title">{{result.title || '无标题'}}</text>
        <text class="result-author">👤 {{result.author || '未知作者'}}</text>
      </view>
    </view>

    <view class="divider" />

    <!-- 下载进度 -->
    <view class="progress-block" wx:if="{{downloadStatus}}">
      <view class="progress-info-row">
        <text class="progress-label-text">
          {{downloadStatus === 'saving' ? '⏳ 保存到相册中...' : '⬇️ 下载中 ' + downloadProgress + '%'}}
        </text>
        <view class="progress-pct-badge">{{downloadStatus === 'saving' ? '100%' : downloadProgress + '%'}}</view>
      </view>
      <view class="progress-bar-bg">
        <view class="progress-bar-fill" style="width: {{downloadStatus === 'saving' ? 100 : downloadProgress}}%"></view>
      </view>
    </view>

    <!-- 下载选项 -->
    <view class="download-section">
      <view class="section-title">📥 选择清晰度下载</view>
      <view class="quality-list">
        <view class="quality-row" wx:for="{{result.videoUrls}}" wx:key="quality">
          <view class="quality-info">
            <view class="quality-dot"></view>
            <text class="quality-name">{{item.quality}}</text>
          </view>
          <view class="quality-actions">
            <view
              class="btn-dl {{downloadingIndex === index ? 'btn-dl-loading' : ''}}"
              bindtap="downloadVideo"
              data-url="{{item.url}}"
              data-quality="{{item.quality}}"
              data-index="{{index}}"
            >
              <text wx:if="{{downloadingIndex === index}}">{{downloadProgress}}%</text>
              <text wx:else>⬇️ 下载</text>
            </view>
            <view class="btn-copy-sm" bindtap="copyUrl" data-url="{{item.url}}">📋</view>
          </view>
        </view>
      </view>
    </view>

    <view class="tip-box" wx:if="{{result.platform === 'bilibili'}}">
      ⚠️ B站视频音视频分离，需分别下载后合并
    </view>
  </view>

  <!-- 使用说明 -->
  <view class="card guide-card">
    <view class="guide-title">📖 使用说明</view>
    <view class="guide-steps">
      <view class="guide-step" wx:for="{{steps}}" wx:key="index">
        <view class="step-num">{{index + 1}}</view>
        <text class="step-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 悬浮进度条 -->
  <view class="float-progress" wx:if="{{downloadStatus}}">
    <text class="float-label">{{downloadStatus === 'saving' ? '⏳ 保存中...' : '⬇️ 下载中 ' + downloadProgress + '%'}}</text>
    <view class="progress-bar-bg">
      <view class="progress-bar-fill" style="width: {{downloadStatus === 'saving' ? 100 : downloadProgress}}%"></view>
    </view>
  </view>
</view>
