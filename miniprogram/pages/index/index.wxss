.page { min-height: 100vh; background: var(--bg-page); padding-bottom: 40rpx; }

/* Hero */
.hero { padding: 50rpx 32rpx 44rpx; text-align: center; }
.hero-top-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.hero-badge {
  background: rgba(255,255,255,0.22); color: #fff;
  font-size: 22rpx; padding: 6rpx 24rpx;
  border-radius: var(--radius-full);
  border: 1rpx solid rgba(255,255,255,0.3);
}
.theme-btn {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx;
  border: 1rpx solid rgba(255,255,255,0.3);
}
.hero-title { display: block; font-size: 56rpx; font-weight: 900; color: #fff; margin-bottom: 12rpx; letter-spacing: 2rpx; }
.hero-sub { display: block; font-size: 26rpx; color: rgba(255,255,255,0.82); margin-bottom: 28rpx; }
.platform-chips { display: flex; flex-wrap: wrap; gap: 12rpx; justify-content: center; }
.chip { background: rgba(255,255,255,0.18); color: #fff; font-size: 22rpx; padding: 6rpx 20rpx; border-radius: var(--radius-full); border: 1rpx solid rgba(255,255,255,0.25); }

/* 输入卡片 */
.input-card { padding: 32rpx; margin: -20rpx 24rpx 20rpx; }
.input-label { font-size: 26rpx; font-weight: 600; color: var(--text-secondary); margin-bottom: 16rpx; }
.url-input {
  width: 100%; min-height: 120rpx;
  background: var(--bg-input); border-radius: var(--radius-md);
  border: 2rpx solid var(--border-color);
  padding: 20rpx 24rpx; font-size: 28rpx; color: var(--text-primary);
  line-height: 1.6; box-sizing: border-box;
}
.btn-row { display: flex; align-items: center; justify-content: space-between; margin-top: 20rpx; gap: 16rpx; }
.btn-clear-sm {
  font-size: 26rpx; color: var(--text-secondary);
  background: var(--bg-input); border: 1rpx solid var(--border-color);
  border-radius: var(--radius-full); padding: 14rpx 28rpx; flex-shrink: 0;
}
.parse-btn-wrap { flex: 1; display: flex; justify-content: flex-end; }
.btn-parse {
  width: 100%; height: 88rpx; line-height: 88rpx;
  border-radius: var(--radius-full); border: none;
  color: #fff; font-size: 32rpx; font-weight: 700;
  text-align: center; letter-spacing: 2rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.2);
}
.btn-parse-loading { opacity: 0.7; }

/* 结果卡片 */
.result-card { padding: 28rpx; margin: 0 24rpx 20rpx; }
.result-header { display: flex; gap: 20rpx; align-items: flex-start; margin-bottom: 24rpx; }
.cover-wrap { position: relative; flex-shrink: 0; }
.cover-img { width: 160rpx; height: 120rpx; border-radius: var(--radius-md); display: block; background: var(--bg-input); }
.cover-placeholder { width: 160rpx; height: 120rpx; border-radius: var(--radius-md); background: var(--bg-input); display: flex; align-items: center; justify-content: center; font-size: 48rpx; }
.cover-platform-badge { position: absolute; bottom: 8rpx; left: 8rpx; color: #fff; font-size: 18rpx; padding: 4rpx 12rpx; border-radius: var(--radius-full); }
.result-meta { flex: 1; overflow: hidden; }
.result-title { display: block; font-size: 28rpx; font-weight: 700; color: var(--text-primary); line-height: 1.5; margin-bottom: 12rpx; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.result-author { display: block; font-size: 24rpx; color: var(--text-muted); }
.divider { height: 1rpx; background: var(--border-color); margin: 0 0 24rpx; }

/* 进度块 */
.progress-block { background: var(--bg-input); border-radius: var(--radius-md); padding: 20rpx 24rpx; margin-bottom: 24rpx; }
.progress-info-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14rpx; }
.progress-label-text { font-size: 26rpx; font-weight: 500; }
.progress-pct-badge { color: #fff; font-size: 20rpx; font-weight: 700; padding: 4rpx 16rpx; border-radius: var(--radius-full); }

/* 下载区 */
.download-section { }
.section-title { font-size: 26rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 16rpx; }
.quality-list { display: flex; flex-direction: column; gap: 12rpx; }
.quality-row { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 20rpx; background: var(--bg-input); border-radius: var(--radius-md); border: 1rpx solid var(--border-color); }
.quality-info { display: flex; align-items: center; gap: 14rpx; }
.quality-dot { width: 12rpx; height: 12rpx; border-radius: 50%; flex-shrink: 0; }
.quality-name { font-size: 28rpx; font-weight: 600; color: var(--text-primary); }
.quality-actions { display: flex; gap: 12rpx; align-items: center; }
.tip-box { margin-top: 20rpx; padding: 16rpx 20rpx; background: #fffbe6; border-radius: var(--radius-md); font-size: 24rpx; color: #b45309; border: 1rpx solid #fde68a; }

/* 使用说明 */
.guide-card { padding: 28rpx; margin: 0 24rpx 20rpx; }
.guide-title { font-size: 28rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 20rpx; }
.guide-steps { display: flex; flex-direction: column; gap: 16rpx; }
.guide-step { display: flex; align-items: flex-start; gap: 16rpx; }
.step-num { flex-shrink: 0; width: 40rpx; height: 40rpx; border-radius: 50%; color: #fff; font-size: 22rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; }
.step-text { font-size: 26rpx; color: var(--text-secondary); line-height: 1.7; padding-top: 6rpx; }

/* 主题弹窗 */
.theme-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 200; display: flex; align-items: flex-end; }
.theme-panel { width: 100%; background: var(--bg-card); border-radius: var(--radius-xl) var(--radius-xl) 0 0; padding: 32rpx 32rpx 60rpx; }
.theme-panel-title { font-size: 32rpx; font-weight: 800; color: var(--text-primary); text-align: center; margin-bottom: 28rpx; }
.theme-list { display: flex; flex-direction: column; gap: 12rpx; }
.theme-item { display: flex; align-items: center; gap: 20rpx; padding: 20rpx 24rpx; border-radius: var(--radius-md); border: 2rpx solid var(--border-color); background: var(--bg-input); }
.theme-item-active { border-color: var(--color-primary); background: var(--bg-tag); }
.theme-color-dot { width: 48rpx; height: 48rpx; border-radius: 50%; flex-shrink: 0; }
.theme-name { flex: 1; font-size: 28rpx; font-weight: 600; color: var(--text-primary); }
.theme-check { font-size: 32rpx; color: var(--color-primary); font-weight: 700; }
