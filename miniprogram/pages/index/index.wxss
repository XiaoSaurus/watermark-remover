.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 40rpx;
}
.hero {
  display: flex; flex-direction: column; align-items: center;
  padding: 60rpx 32rpx 32rpx;
}
.hero-title { font-size: 48rpx; font-weight: 800; color: #fff; margin-bottom: 12rpx; }
.hero-sub { font-size: 26rpx; color: rgba(255,255,255,0.85); }

.input-card { margin: 0 24rpx; }
.url-input { width: 100%; min-height: 140rpx; font-size: 28rpx; color: #333; line-height: 1.6; box-sizing: border-box; }
.btn-row { display: flex; justify-content: flex-end; align-items: center; gap: 20rpx; margin-top: 20rpx; }
.btn-clear { color: #999; font-size: 26rpx; padding: 12rpx 24rpx; }
.btn-primary {
  background: linear-gradient(135deg, #667eea, #764ba2) !important;
  color: #fff !important; border-radius: 50rpx !important;
  font-size: 28rpx !important; font-weight: 600 !important;
  border: none !important; padding: 0 48rpx !important;
  height: 80rpx !important; line-height: 80rpx !important;
}
.btn-primary[disabled] { opacity: 0.5 !important; }

.platforms { display: flex; flex-wrap: wrap; gap: 16rpx; justify-content: center; padding: 24rpx 32rpx; }
.platform-tag { background: rgba(255,255,255,0.2); color: #fff; padding: 8rpx 24rpx; border-radius: 30rpx; font-size: 24rpx; }

.result-card { margin: 0 24rpx 24rpx; }
.result-header { display: flex; gap: 24rpx; align-items: flex-start; margin-bottom: 24rpx; }
.cover { width: 160rpx; height: 120rpx; border-radius: 12rpx; flex-shrink: 0; background: #f0f0f0; }
.cover-placeholder { width: 160rpx; height: 120rpx; border-radius: 12rpx; background: #f0f0ff; display: flex; align-items: center; justify-content: center; font-size: 48rpx; flex-shrink: 0; }
.result-meta { flex: 1; overflow: hidden; }
.platform-badge { display: inline-block; background: #f0f0ff; color: #667eea; padding: 4rpx 16rpx; border-radius: 20rpx; font-size: 22rpx; margin-bottom: 12rpx; }
.video-title { display: block; font-size: 28rpx; font-weight: 600; color: #222; line-height: 1.5; margin-bottom: 8rpx; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.video-author { font-size: 24rpx; color: #888; }
.divider { height: 1rpx; background: #f0f0f0; margin: 24rpx 0; }

/* 进度条 */
.progress-wrap { margin-bottom: 24rpx; padding: 20rpx 24rpx; background: #f8f9ff; border-radius: 12rpx; }
.progress-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.progress-label { font-size: 26rpx; color: #667eea; font-weight: 500; }
.progress-pct { font-size: 26rpx; color: #667eea; font-weight: 700; }
.progress-bar-bg { height: 12rpx; background: #e8eaff; border-radius: 6rpx; overflow: hidden; }
.progress-bar-fill { height: 100%; background: linear-gradient(90deg, #667eea, #764ba2); border-radius: 6rpx; transition: width 0.2s ease; }

.section-title { display: block; font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 20rpx; }
.download-list { display: flex; flex-direction: column; gap: 16rpx; }
.download-item { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 24rpx; background: #f8f9ff; border-radius: 12rpx; }
.quality-label { font-size: 28rpx; font-weight: 600; color: #333; }
.download-btns { display: flex; gap: 12rpx; }
.btn-download { background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; padding: 12rpx 28rpx; border-radius: 30rpx; font-size: 24rpx; min-width: 100rpx; text-align: center; }
.btn-downloading { background: linear-gradient(135deg, #999, #bbb) !important; }
.btn-copy { background: #f0f0ff; color: #667eea; padding: 12rpx 24rpx; border-radius: 30rpx; font-size: 24rpx; }
.tip-box { margin-top: 20rpx; padding: 16rpx 20rpx; background: #fff8e6; border-radius: 10rpx; font-size: 24rpx; color: #e6a817; }

.guide-card { margin: 0 24rpx 24rpx; }
.guide-title { display: block; font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 20rpx; }
.guide-steps { display: flex; flex-direction: column; gap: 16rpx; }
.step { display: flex; align-items: flex-start; gap: 16rpx; }
.step-num { width: 44rpx; height: 44rpx; background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; border-radius: 50%; font-size: 24rpx; font-weight: 600; display: flex; align-items: center; justify-content: center; flex-shrink: 0; line-height: 44rpx; text-align: center; }
.step-text { font-size: 26rpx; color: #555; line-height: 1.6; padding-top: 8rpx; }
