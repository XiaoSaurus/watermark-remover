<view class="container">
  <view class="header">
    <text class="header-title">📥 下载历史</text>
    <view class="btn-clear-all" bindtap="clearAll" wx:if="{{list.length > 0}}">清空</view>
  </view>

  <view class="loading-wrap" wx:if="{{pageLoading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <view class="empty" wx:elif="{{list.length === 0}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无下载记录</text>
    <text class="empty-sub">去解析历史中下载视频吧～</text>
  </view>

  <view class="list" wx:else>
    <view class="item card" wx:for="{{list}}" wx:key="id">
      <image class="item-cover" src="{{item.cover}}" mode="aspectFill" wx:if="{{item.cover}}" />
      <view class="item-cover-placeholder" wx:else><text>🎬</text></view>
      <view class="item-info">
        <text class="item-title">{{item.title || '无标题'}}</text>
        <view class="item-meta">
          <text class="tag-platform">{{platformMap[item.platform] || item.platform}}</text>
          <text class="tag-quality">{{item.quality}}</text>
          <text class="tag-status tag-success" wx:if="{{item.status === 'success'}}">✅ 成功</text>
          <text class="tag-status tag-fail" wx:elif="{{item.status === 'fail'}}">❌ 失败</text>
        </view>
        <view class="item-bottom">
          <text class="item-time">{{item.timeStr}}</text>
          <text class="item-errmsg" wx:if="{{item.status === 'fail' && item.errMsg}}">{{item.errMsg}}</text>
        </view>
      </view>
      <view class="btn-delete" bindtap="deleteItem" data-id="{{item.id}}">删除</view>
    </view>
  </view>
</view>
