.page { min-height: 100vh; background: var(--bg-page); padding-bottom: 40rpx; }

.page-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
  background: var(--bg-card);
  border-bottom: 1rpx solid var(--border-color);
  position: sticky; top: 0; z-index: 10;
}
.page-title-wrap { display: flex; align-items: center; gap: 12rpx; }
.page-title { font-size: 32rpx; font-weight: 800; color: var(--text-primary); }
.count-badge {
  background: var(--gradient-btn); color: #fff;
  font-size: 20rpx; font-weight: 700;
  padding: 4rpx 14rpx; border-radius: var(--radius-full);
}
.btn-clear-all { font-size: 26rpx; color: var(--color-danger); padding: 8rpx 16rpx; }

.list { padding: 20rpx 24rpx 0; display: flex; flex-direction: column; gap: 14rpx; }
.history-item { display: flex; gap: 16rpx; align-items: center; padding: 20rpx 24rpx; margin: 0; }
.item-cover { width: 110rpx; height: 82rpx; border-radius: var(--radius-md); flex-shrink: 0; background: var(--bg-input); }
.cover-ph-sm {
  width: 110rpx; height: 82rpx; border-radius: var(--radius-md);
  background: var(--bg-input); display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; flex-shrink: 0;
}
.item-info { flex: 1; overflow: hidden; }
.item-title {
  display: block; font-size: 26rpx; font-weight: 600; color: var(--text-primary);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 10rpx;
}
.item-tags { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 8rpx; align-items: center; }
.item-bottom { display: flex; align-items: center; gap: 12rpx; flex-wrap: wrap; }
.item-time { font-size: 20rpx; color: var(--text-muted); }
.item-errmsg { font-size: 20rpx; color: var(--color-danger); }
.btn-del-circle {
  flex-shrink: 0; width: 48rpx; height: 48rpx; border-radius: 50%;
  background: var(--color-danger-bg); color: var(--color-danger);
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; font-weight: 700;
}
