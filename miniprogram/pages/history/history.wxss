.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 40rpx;
}
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
}
.header-title { font-size: 32rpx; font-weight: 700; color: #333; }
.btn-clear-all { font-size: 26rpx; color: #e74c3c; padding: 8rpx 16rpx; }

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 32rpx; color: #555; margin-bottom: 12rpx; }
.empty-sub { font-size: 26rpx; color: #aaa; }

.list { padding: 0 24rpx; }
.item {
  display: flex;
  gap: 20rpx;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 20rpx 24rpx;
}
.item-cover {
  width: 120rpx;
  height: 90rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}
.item-cover-placeholder {
  width: 120rpx;
  height: 90rpx;
  border-radius: 10rpx;
  background: #f0f0ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}
.item-info { flex: 1; overflow: hidden; }
.item-title {
  display: block;
  font-size: 26rpx;
  color: #222;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}
.item-meta { display: flex; gap: 12rpx; margin-bottom: 6rpx; }
.item-platform {
  font-size: 22rpx;
  color: #667eea;
  background: #f0f0ff;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
}
.item-quality {
  font-size: 22rpx;
  color: #888;
  background: #f5f5f5;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
}
.item-time { font-size: 22rpx; color: #bbb; }