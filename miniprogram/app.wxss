page {
  /* 默认主题变量（由 JS 动态覆盖） */
  --color-primary: #6c63ff;
  --color-primary-light: #8b85ff;
  --gradient-btn: linear-gradient(135deg, #6c63ff, #764ba2);
  --gradient-bg: linear-gradient(135deg, #667eea 0%, #764ba2 100%);

  /* 固定变量 */
  --bg-page: #f0f2f8;
  --bg-card: #ffffff;
  --bg-input: #f8f9ff;
  --bg-tag: #f0f0ff;
  --text-primary: #1a1a2e;
  --text-secondary: #555577;
  --text-muted: #9999bb;
  --border-color: #e8eaf6;
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;
  --radius-full: 9999rpx;
  --shadow-card: 0 4rpx 24rpx rgba(0,0,0,0.07);
  --shadow-btn: 0 6rpx 20rpx rgba(108,99,255,0.35);
  --color-success: #18a058;
  --color-success-bg: #f0faf0;
  --color-danger: #d03050;
  --color-danger-bg: #fff0f0;

  background-color: var(--bg-page);
  font-family: -apple-system, "PingFang SC", "HarmonyOS Sans", sans-serif;
  color: var(--text-primary);
}

/* 通用卡片 */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--border-color);
  overflow: hidden;
}

/* 通用按钮 */
.btn-primary {
  background: var(--gradient-btn);
  color: #fff;
  border-radius: var(--radius-full);
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  padding: 0 48rpx;
  height: 88rpx;
  line-height: 88rpx;
  box-shadow: var(--shadow-btn);
}
.btn-primary[disabled] { opacity: 0.5; box-shadow: none; }

/* 标签 */
.tag {
  display: inline-flex; align-items: center;
  font-size: 20rpx; padding: 4rpx 16rpx;
  border-radius: var(--radius-full); font-weight: 500;
}
.tag-platform { color: var(--color-primary); background: var(--bg-tag); }
.tag-quality  { color: var(--text-secondary); background: var(--bg-input); border: 1rpx solid var(--border-color); }
.tag-success  { color: var(--color-success); background: var(--color-success-bg); }
.tag-fail     { color: var(--color-danger); background: var(--color-danger-bg); }

/* 进度条 */
.progress-bar-bg { height: 12rpx; background: #e8eaff; border-radius: var(--radius-full); overflow: hidden; }
.progress-bar-fill { height: 100%; background: var(--gradient-btn); border-radius: var(--radius-full); transition: width 0.2s ease; }

/* 悬浮进度条 */
.float-progress {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--bg-card); padding: 20rpx 32rpx 40rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.1);
  border-top: 1rpx solid var(--border-color); z-index: 100;
}
.float-label { display: block; font-size: 26rpx; color: var(--color-primary); font-weight: 500; margin-bottom: 14rpx; }

/* 空状态 */
.empty-wrap { display: flex; flex-direction: column; align-items: center; padding: 120rpx 32rpx; }
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 30rpx; color: var(--text-secondary); margin-bottom: 10rpx; font-weight: 500; }
.empty-sub  { font-size: 26rpx; color: var(--text-muted); }

/* 加载 */
.loading-wrap { display: flex; justify-content: center; padding: 100rpx; }
.loading-spinner {
  width: 60rpx; height: 60rpx;
  border: 6rpx solid var(--border-color);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* 页头 */
.page-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 32rpx 20rpx;
  background: var(--bg-card);
  border-bottom: 1rpx solid var(--border-color);
}
.page-title-wrap { display: flex; align-items: center; gap: 12rpx; }
.page-title { font-size: 32rpx; font-weight: 800; color: var(--text-primary); }
.count-badge {
  background: var(--gradient-btn); color: #fff;
  font-size: 20rpx; font-weight: 700;
  padding: 4rpx 14rpx; border-radius: var(--radius-full);
}
.btn-clear-all { font-size: 26rpx; color: var(--color-danger); padding: 8rpx 16rpx; }

/* 下载按钮 */
.btn-dl {
  background: var(--gradient-btn); color: #fff;
  padding: 12rpx 28rpx; border-radius: var(--radius-full);
  font-size: 26rpx; font-weight: 600; min-width: 110rpx; text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}
.btn-dl-loading { background: linear-gradient(135deg,#999,#bbb); box-shadow: none; }
.btn-copy-sm { background: var(--bg-tag); color: var(--color-primary); padding: 12rpx 20rpx; border-radius: var(--radius-full); font-size: 26rpx; }

/* 删除圆钮 */
.btn-del-circle {
  flex-shrink: 0; width: 52rpx; height: 52rpx; border-radius: 50%;
  background: var(--color-danger-bg); color: var(--color-danger);
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; font-weight: 700;
}

/* 下载区 */
.download-area { border-top: 1rpx solid var(--border-color); padding: 16rpx 0 0; }
.download-area-title { font-size: 24rpx; font-weight: 600; color: var(--text-secondary); margin-bottom: 12rpx; }
.dl-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14rpx 16rpx; background: var(--bg-input);
  border-radius: var(--radius-md); margin-bottom: 10rpx;
  border: 1rpx solid var(--border-color);
}
.dl-row:last-child { margin-bottom: 0; }
.dl-quality { display: flex; align-items: center; gap: 12rpx; }
.quality-dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--gradient-btn); flex-shrink: 0; }
.dl-quality text { font-size: 28rpx; font-weight: 600; color: var(--text-primary); }
.dl-actions { display: flex; gap: 10rpx; align-items: center; }
