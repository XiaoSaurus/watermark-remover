/* ===== 设计系统 ===== */
page {
  --color-primary: #6c63ff;
  --color-primary-light: #8b85ff;
  --gradient-btn: linear-gradient(135deg, #6c63ff, #764ba2);
  --gradient-bg: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  --bg-page: #f0f2f8;
  --bg-card: #ffffff;
  --bg-input: #f8f9ff;
  --bg-tag: #f0f0ff;
  --text-primary: #1a1a2e;
  --text-secondary: #555577;
  --text-muted: #9999bb;
  --border-color: #e8eaf6;
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;
  --radius-full: 9999rpx;
  --shadow-card: 0 4rpx 24rpx rgba(0,0,0,0.07);
  --shadow-md: 0 8rpx 32rpx rgba(108,99,255,0.12);
  --color-success: #18a058;
  --color-success-bg: #f0faf0;
  --color-danger: #d03050;
  --color-danger-bg: #fff0f0;
  background-color: var(--bg-page);
  font-family: -apple-system, "PingFang SC", "HarmonyOS Sans", sans-serif;
  color: var(--text-primary);
}

/* ===== 通用卡片 ===== */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--border-color);
  margin: 0 24rpx 20rpx;
  overflow: hidden;
}

/* ===== 通用按钮 ===== */
.btn-primary {
  background: var(--gradient-btn);
  color: #fff;
  border-radius: var(--radius-full);
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  padding: 0 48rpx;
  height: 88rpx;
  line-height: 88rpx;
  box-shadow: 0 6rpx 20rpx rgba(108,99,255,0.35);
}
.btn-primary[disabled] { opacity: 0.5; box-shadow: none; }

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-full);
  font-size: 28rpx;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
}

/* ===== 标签 ===== */
.tag {
  display: inline-flex;
  align-items: center;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  font-weight: 500;
}
.tag-platform { color: var(--color-primary); background: var(--bg-tag); }
.tag-quality  { color: var(--text-secondary); background: var(--bg-input); border: 1rpx solid var(--border-color); }
.tag-success  { color: var(--color-success); background: var(--color-success-bg); }
.tag-fail     { color: var(--color-danger); background: var(--color-danger-bg); }

/* ===== 进度条 ===== */
.progress-bar-bg {
  height: 12rpx;
  background: #e8eaff;
  border-radius: var(--radius-full);
  overflow: hidden;
}
.progress-bar-fill {
  height: 100%;
  background: var(--gradient-btn);
  border-radius: var(--radius-full);
  transition: width 0.2s ease;
}

/* ===== 悬浮进度条 ===== */
.float-progress {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--bg-card);
  padding: 20rpx 32rpx 40rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.1);
  border-top: 1rpx solid var(--border-color);
  z-index: 100;
}
.float-label {
  display: block;
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 500;
  margin-bottom: 14rpx;
}

/* ===== 空状态 ===== */
.empty-wrap {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 32rpx;
}
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 30rpx; color: var(--text-secondary); margin-bottom: 10rpx; font-weight: 500; }
.empty-sub  { font-size: 26rpx; color: var(--text-muted); }

/* ===== 加载 ===== */
.loading-wrap {
  display: flex; justify-content: center; align-items: center;
  padding: 100rpx;
}
.loading-spinner {
  width: 60rpx; height: 60rpx;
  border: 6rpx solid var(--border-color);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
